---
interface Props {
  name: string;
  tagline: string;
  description: string;
  includes: string[];
  cta: string;
  delay?: string;
}

const { name, tagline, description, includes, cta, delay = '' } = Astro.props;
---

<article class:list={['group p-8 border border-gold/20 rounded-sm transition-all duration-500 hover:border-gold/50 hover:bg-night/50 flex flex-col reveal', delay]}>
  <h3 class="font-display text-2xl font-semibold text-gold mb-1">{name}</h3>
  <p class="font-heading font-light text-parchment/60 text-sm mb-3">{tagline}</p>
  <p class="font-body font-light text-parchment/70 leading-relaxed text-sm mb-6">{description}</p>
  <ul class="space-y-2 mb-8 flex-grow">
    {includes.map((item) => (
      <li class="flex items-start gap-2 font-body font-light text-parchment/70 text-sm">
        <span class="text-gold mt-0.5">✦</span>
        <span>{item}</span>
      </li>
    ))}
  </ul>
  <a
    href={cta}
    target="_blank"
    rel="noopener noreferrer"
    class="cta-button-outline text-center"
  >
    Consultar por WhatsApp
  </a>
</article>