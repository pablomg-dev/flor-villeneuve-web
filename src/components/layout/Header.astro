---
import Nav from './Nav.astro';
import type { NavItem } from '../../types';

const navItems: NavItem[] = [
  { label: 'Inicio', href: '/' },
  { label: 'Mentoría', href: '/mentoria' },
  { label: 'Formación', href: '/formacion' },
  { label: 'Packs', href: '/packs' },
  { label: 'Creativos', href: '/creativos' },
  { label: 'Bio', href: '/bio' },
  { label: 'Contacto', href: '/contacto' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-deep/95 backdrop-blur-sm border-b border-gold/10">
  <div class="container-padding flex items-center justify-between py-4">
    <a href="/" class="font-display text-lg md:text-xl lg:text-2xl font-semibold text-gold tracking-wide">
      Florencia Villeneuve
    </a>

    <button
      id="menu-toggle"
      class="md:hidden text-gold p-2 focus:outline-none"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <Nav items={navItems} mobileOpen={false} />
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const nav = document.querySelector('nav');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));

    if (nav) {
      nav.classList.toggle('max-h-96');
      nav.classList.toggle('opacity-100');
      nav.classList.toggle('max-h-0');
      nav.classList.toggle('opacity-0');
      nav.classList.toggle('absolute');
      nav.classList.toggle('top-full');
      nav.classList.toggle('left-0');
      nav.classList.toggle('right-0');
      nav.classList.toggle('bg-night');
      nav.classList.toggle('px-6');
      nav.classList.toggle('py-6');
      nav.classList.toggle('border-b');
      nav.classList.toggle('border-gold/10');
    }
  });
</script>