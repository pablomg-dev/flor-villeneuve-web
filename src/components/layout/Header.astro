---
import Nav from './Nav.astro';
import type { NavItem } from '../../types';

    const navItems: NavItem[] = [
    { label: 'Inicio', href: '/' },
    { label: 'Mentoría', href: '/mentoria' },
    { label: 'Formación', href: '/formacion' },
    { label: 'Arteterapia', href: '/arteterapia' },
    { label: 'Bio', href: '/bio' },
    { label: 'Contacto', href: '/contacto' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-deep/95 backdrop-blur-sm border-b border-gold/10">
  <div class="container-padding flex items-center justify-between py-4">
    <a href="/" class="font-display text-lg md:text-xl lg:text-2xl font-semibold text-gold tracking-wide">
      Florencia Villeneuve
    </a>

    <button
      id="menu-toggle"
      class="md:hidden text-gold p-2 focus:outline-none flex-shrink-0"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <Nav items={navItems} mobileOpen={false} />
  </div>

  <nav id="mobile-menu" class="md:hidden hidden absolute top-full left-0 right-0 bg-night px-6 py-6 border-b border-gold/10 transition-all duration-300 ease-in-out opacity-0 -translate-y-2 invisible">
    {navItems.map((item) => (
      <a
        href={item.href}
        class="font-body font-light text-parchment/80 tracking-wide transition-colors duration-300 hover:text-gold py-3 block"
      >
        {item.label}
      </a>
    ))}
  </nav>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  toggle?.addEventListener('click', () => {
    const isOpen = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isOpen));

    if (menu) {
      if (menu.classList.contains('hidden')) {
        menu.classList.remove('hidden');
        requestAnimationFrame(() => {
          menu.classList.add('opacity-100', 'translate-y-0', 'visible');
          menu.classList.remove('opacity-0', '-translate-y-2', 'invisible');
        });
      } else {
        menu.classList.add('opacity-0', '-translate-y-2', 'invisible');
        menu.classList.remove('opacity-100', 'translate-y-0', 'visible');
        setTimeout(() => {
          menu.classList.add('hidden');
        }, 300);
      }
    }
  });
</script>