---
import type { NavItem } from '../../types';

export interface Props {
  items: NavItem[];
  mobileOpen: boolean;
}

const { items, mobileOpen } = Astro.props;
---

<nav class:list={['flex flex-col md:flex-row md:items-center md:gap-8 overflow-hidden transition-[max-height,opacity] duration-300 ease-in-out', mobileOpen ? 'max-h-96 opacity-100' : 'max-h-0 opacity-0 md:max-h-none md:opacity-100']}>
  {items.map((item) => (
    <a
      href={item.href}
      class="font-body font-light text-parchment/80 tracking-wide transition-colors duration-300 hover:text-gold py-3 md:py-0 block md:inline"
    >
      {item.label}
    </a>
  ))}
</nav>