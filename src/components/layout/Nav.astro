---
import type { NavItem } from '../../types';

export interface Props {
  items: NavItem[];
  mobileOpen: boolean;
}

const { items, mobileOpen } = Astro.props;
---

<nav class="hidden md:flex md:flex-row md:items-center md:gap-8">
  {items.map((item) => (
    <a
      href={item.href}
      class="font-body font-light text-parchment/80 tracking-wide transition-colors duration-300 hover:text-gold py-0"
    >
      {item.label}
    </a>
  ))}
</nav>