---
import ServiceCard from '../ui/ServiceCard.astro';
import SectionTitle from '../ui/SectionTitle.astro';

const services = [
  {
    title: 'Simbología',
    description: 'Lectura del tarot akáshico como herramienta de autoconocimiento profundo. Cada carta es un símbolo vivo que habla de tu historia, tus sombras y su luz.',
    icon: '/img/tarot.svg',
    href: '/formacion/tarot',
  },
  {
    title: 'Arte',
    description: 'Astrología simbólica y vivencial. Tu carta natal como mapa del alma, los tránsitos como clima interior. Un lenguaje ancestral para leer tu presente.',
    icon: '/img/astrologia.svg',
    href: '/formacion/astrologia',
  },
  {
    title: 'Psicología',
    description: 'Los números como lenguaje simbólico. Camino de vida, expresión, alma y ciclos. Una herramienta más para comprender tu diseño único.',
    icon: '/img/numerologia.svg',
    href: '/formacion/numerologia',
  },
];
---

<section class="section-padding bg-deep">
  <div class="container-padding">
    <SectionTitle
      title="Tres lenguajes, un camino"
      subtitle="Simbología, arte y psicología: tres formas de leer lo simbólico y acompañar procesos de transformación."
    />
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {services.map((service, i) => (
        <ServiceCard {...service} delay={`reveal-delay-${i}`} />
      ))}
    </div>
  </div>
</section>