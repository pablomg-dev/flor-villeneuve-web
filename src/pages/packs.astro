---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
---

<BaseLayout title="Packs" description="Packs de consultas con Florencia Villeneuve." canonical="/packs">
  <Header />
  <main>
    <section class="section-padding bg-deep pt-32">
      <div class="container-padding text-center">
        <p class="font-body font-light text-parchment/70 leading-relaxed">
          Esta página ha sido integrada en la sección de Mentoría.
        </p>
        <a href="/mentoria" class="inline-block mt-6 font-body font-medium text-gold text-sm tracking-wide border-b border-gold/30 pb-0.5 hover:border-gold transition-colors duration-300">
          Ver mentoría
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>