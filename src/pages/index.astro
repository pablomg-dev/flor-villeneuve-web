---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Services from '../components/sections/Services.astro';
import About from '../components/sections/About.astro';
import Contact from '../components/sections/Contact.astro';
import Testimonials from '../components/sections/Testimonials.astro';

---

<BaseLayout
  title="Mentora en Uruguay y Argentina"
  description="Florencia Villeneuve — Mentora, guía en simbología, arte y psicología. Sesiones online para Uruguay y Argentina (Montevideo, Buenos Aires, Punta del Este, Rosario, Córdoba y más)."
  keywords="Florencia Villeneuve, mentora, simbología, arte terapia, tarot, astrología, numerología, coaching ontológico, psicología jungiana, transformación personal, autoconocimiento, procesos internos, Montevideo, Uruguay, Punta del Este, Buenos Aires, CABA, Argentina, Rosario, Córdoba, Sesiones online Argentina, Consultas online Uruguay"
>
  <Header />
  <main>
    <Hero />
    <Services />
    <About />
    <Testimonials />
    <Contact />
  </main>
  <Footer />
</BaseLayout>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Florencia Villeneuve",
  "url": "https://florenciavilleneuve.com",
  "jobTitle": "Mentora",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Montevideo",
    "addressCountry": "UY"
  },
  "areaServed": [
    {
      "@type": "Country",
      "name": "Uruguay"
    },
    {
      "@type": "Country",
      "name": "Argentina"
    }
  ],
  "sameAs": [
    "https://instagram.com/florencia.villeneuve"
  ]
}
</script>